  <property name="styleSheet">
   <string notr="true">* {
    font-family: 'Poppins';
    letter-spacing: 0.6px;
}

#Author {
    background: url(:/img/img/author_bg.png) no-repeat;
}

#headerWidget {
    background-color: #333333;
}

#headerWidget {
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
}

#headingLabel {
    font-size: 12px;
    font-weight: 700;
}

#exitBtn {
    border: 0;
    border-radius: 10px;
    background-color: #FF3C3C;
}

#exitBtn:hover {
    background-color: #FF5757;
}

#copyEmailBtn {
    border-image: url(:/icon/img/copy.png) no-repeat;
}

#githubBtn {
    border-image: url(:/icon/img/github.png);
}

#copyEmailBtn:hover {
    border-image: url(:/icon/img/copy_hover.png) no-repeat;
}

#githubBtn:hover {
    border-image: url(:/icon/img/github_hover.png);
}</string>
